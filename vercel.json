{
  "version": 2,
  "name": "pinboard-gpt",
  "buildCommand": "npm run build:website",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node@3.1.0"
    },
    {
      "src": "website/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/install",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/website/$1"
    }
  ]
}