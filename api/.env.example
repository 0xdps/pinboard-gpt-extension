# Environment Variables for Google OAuth

# Get these from Google Cloud Console:
# https://console.cloud.google.com/apis/credentials

# Your Google OAuth Client ID
GOOGLE_CLIENT_ID=221029032826-86aonba202qa51luivhfm0psou37492m.apps.googleusercontent.com

# Your Google OAuth Client Secret (get this from Google Cloud Console)
GOOGLE_CLIENT_SECRET=your-client-secret-here

# JWT Secret for generating tokens (generate a random string)
JWT_SECRET=your-random-jwt-secret-here

# Database connection (Turso)
TURSO_DATABASE_URL=your-turso-database-url
TURSO_AUTH_TOKEN=your-turso-auth-token

# Optional: Environment
NODE_ENV=development

# Google OAuth Configuration:
# 
# In Google Cloud Console, configure:
# - Authorized JavaScript origins: https://pinboard-gpt.dps.codes
# - Authorized redirect URIs: https://pinboard-gpt.dps.codes/auth/callback
#
# OAuth Scopes required:
# - https://www.googleapis.com/auth/userinfo.profile
# - https://www.googleapis.com/auth/userinfo.email
